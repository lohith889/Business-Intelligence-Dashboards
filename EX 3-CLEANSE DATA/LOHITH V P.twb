            <column caption='Region Clean' datatype='string' name='[Calculation_1335932928299009]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([Region]) THEN&#13;&#10;    &quot;Unknown&quot;&#13;&#10;ELSEIF LOWER([Region]) = &quot;south&quot; THEN&#13;&#10;    &quot;South&quot;&#13;&#10;ELSEIF [Region] = &quot;South Region&quot; THEN&#13;&#10;    &quot;South&quot;&#13;&#10;ELSE&#13;&#10;    [Region]&#13;&#10;END' />
