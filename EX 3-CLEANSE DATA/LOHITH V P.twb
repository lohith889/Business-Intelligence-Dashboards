    <worksheet name='Sales Distribution by Category (Box Plot)'>
      <table>
        <view>
          <datasources>
            <datasource caption='Sample - Superstore_Modified_For_Experiment' name='federated.0c2h1g41ca5yaw1gdw2fg1788nw0' />
          </datasources>
          <datasource-dependencies datasource='federated.0c2h1g41ca5yaw1gdw2fg1788nw0'>
            <column caption='Sales Clean' datatype='real' name='[Calculation_1335932929601538]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IFNULL([Sales], 229.88)' />
            </column>
            <column caption='Category Clean' datatype='string' name='[Calculation_1335932992552964]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF LOWER([Category]) = &quot;furniture&quot; THEN&#13;&#10;    &quot;Furniture&quot;&#13;&#10;ELSEIF LOWER([Category]) = &quot;office supplies&quot; THEN&#13;&#10;    &quot;Office Supplies&quot;&#13;&#10;ELSEIF LOWER([Category]) = &quot;technology&quot; THEN&#13;&#10;    &quot;Technology&quot;&#13;&#10;ELSE&#13;&#10;    [Category]&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column datatype='string' name='[Order ID]' role='dimension' type='nominal' />
            <column datatype='real' name='[Sales]' role='measure' type='quantitative' />
